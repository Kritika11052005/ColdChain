PROSPEO_API_KEY=your_prospeo_key_here
TOMBA_API_KEY=your_tomba_key_here
TOMBA_API_SECRET=your_tomba_secret_here
GEMINI_API_KEY=your_gemini_key_here
SERPER_API_KEY=your_serper_key_here
BREVO_API_KEY=your_brevo_key_here

# Database (Turso)
# Use https:// scheme instead of libsql:// to avoid Windows WS handshake errors in python client
TURSO_DATABASE_URL=https://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Sender Details (required — pipeline will not start without these)
SENDER_EMAIL=your_sender_email_here
SENDER_NAME=your_sender_name_here
